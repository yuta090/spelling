# =============================================================================
# .env.local の雛形（テンプレート）
# 使い方: このファイルを .env.local にコピーし、実値を記入してください。
#   cp .env.local.example .env.local
# .env.local は .gitignore 済み（コミットされません）。実値はここ(.example)に書かないこと。
#
# 凡例:
#   [PUBLIC] = アプリに埋め込んでよい（公開しても安全）
#   [SECRET] = 絶対にアプリ/クライアントに入れない。サーバー/Edge Function/CLIのみ
# 取得場所などの詳細は docs/supabase-setup.md を参照。
# =============================================================================

# --- フェーズ1: Supabase 接続（今すぐ記入） -------------------------------------
# Supabase ダッシュボード → Project Settings → API
SUPABASE_URL=                 # [PUBLIC] 例: https://abcdefgh.supabase.co
SUPABASE_ANON_KEY=            # [PUBLIC] anon public key（クライアント用・RLSで保護）
SUPABASE_PROJECT_REF=         # [PUBLIC] プロジェクト参照ID（URLのサブドメイン部 例: abcdefgh）

# Project Settings → API（service_role）／ Database（password）
SUPABASE_SERVICE_ROLE_KEY=    # [SECRET] 全権限。Edge Function/管理スクリプト専用。アプリ禁止
SUPABASE_DB_PASSWORD=         # [SECRET] マイグレーション/直接DB接続用（プロジェクト作成時に設定した値）

# --- フェーズ2: 手書き保存ストレージ（後で） ------------------------------------
# まずは Supabase Storage で始め、コスト最適化で Cloudflare R2(転送無料)へ移行可。
# Cloudflare R2 (S3互換) を使う場合:
# R2_ACCOUNT_ID=             # [PUBLIC]
# R2_BUCKET=                 # [PUBLIC] 例: spelling-drawings
# R2_ENDPOINT=               # [PUBLIC] 例: https://<account>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=          # [SECRET] 署名はサーバー/Edgeで
# R2_SECRET_ACCESS_KEY=      # [SECRET]

# --- フェーズ3: プッシュ通知（後で・子の完了→親へ確実通知） ----------------------
# Apple Developer → Keys で APNs 用 .p8 を発行
# APNS_KEY_ID=               # [SECRET]
# APNS_TEAM_ID=              # [SECRET] 既知: 34WGLQNY3N
# APNS_BUNDLE_ID=            # [PUBLIC] com.yuta090.SpellingTrainer
# APNS_AUTH_KEY_FILE=        # [SECRET] .p8 ファイルパス（リポジトリ外）
# FCM_SERVER_KEY=            # [SECRET] Android対応時のみ

# --- フェーズ4: 課金（後で・StoreKit / App Store Server API） --------------------
# App Store Connect → Users and Access → Integrations → App Store Server API
# APP_STORE_ISSUER_ID=       # [SECRET]
# APP_STORE_KEY_ID=          # [SECRET]
# APP_STORE_PRIVATE_KEY_FILE=# [SECRET] .p8 パス
# APP_BUNDLE_ID=             # [PUBLIC] com.yuta090.SpellingTrainer
