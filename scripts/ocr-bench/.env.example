# これをコピーして .env を作り、実際のキーを貼る（.env は gitignore 済み）:
#   cp .env.example .env
# bench.py が同ディレクトリの .env を自動で読み込む。

# OpenRouter の API キー（必須）。https://openrouter.ai/keys で発行。
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx

# Supabase からサンプルを取る場合のみ（ローカル samples/ で試すなら不要）
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJxxxxxxxx   # service_role キー（RLSバイパス／絶対に公開しない）
